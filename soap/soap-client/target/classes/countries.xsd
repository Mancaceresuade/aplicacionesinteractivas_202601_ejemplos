<?xml version="1.0" encoding="UTF-8"?>
<!--
    CONTRATO DEL SERVICIO SOAP (copia en el cliente)
    =================================================
    Este XSD es idéntico al del servidor. En la práctica real, el cliente
    obtendría este contrato de dos maneras:
      1. Copiando el XSD directamente (como hacemos aquí).
      2. Descargando el WSDL del servidor y generando las clases con 'wsimport'.

    El namespace define el paquete Java generado: com.uade.soap.countries
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:tns="http://uade.com/soap/countries"
           targetNamespace="http://uade.com/soap/countries"
           elementFormDefault="qualified">

    <xs:element name="getCountryRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="name" type="xs:string"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="getCountryResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="country" type="tns:country"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:complexType name="country">
        <xs:sequence>
            <xs:element name="name"       type="xs:string"/>
            <xs:element name="population" type="xs:int"/>
            <xs:element name="capital"    type="xs:string"/>
            <xs:element name="currency"   type="tns:currency"/>
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="currency">
        <xs:restriction base="xs:string">
            <xs:enumeration value="GBP"/>
            <xs:enumeration value="EUR"/>
            <xs:enumeration value="PLN"/>
            <xs:enumeration value="ARS"/>
            <xs:enumeration value="USD"/>
        </xs:restriction>
    </xs:simpleType>

</xs:schema>
